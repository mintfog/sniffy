      "notLoaded": "未获取",
      "stateHint": "用于动态签发站点证书以解密 HTTPS 流量",
      "stateLabel": "状态",
      "title": "根证书状态"
    },
    "steps": {
      "android": {
        "1": "将下载好的 .crt 证书文件传输到手机存储中。",
        "2": "打开「设置 - 安全 - 加密与凭据 - 从存储设备安装证书」。",
        "3": "选择证书文件并将用途指定为「CA 证书」，按提示完成安装。",
        "4": "注意 Android 7+ 应用默认不信任用户 CA，调试时需配合可调试应用。"
      },
      "ios": {
        "1": "将 iPhone 的 WiFi 代理指向本机（主机填电脑局域网 IP，端口 8080）。",
        "2": "用 Safari 扫描右侧二维码，或直接输入 {{url}}。",
        "3": "允许下载配置描述文件，前往「设置 - 通用 - VPN 与设备管理」点击安装。",
        "4": "安装后进入「设置 - 通用 - 关于本机 - 证书信任设置」，为 Sniffy Root CA 打开完全信任。"
      },
      "macos": {
        "1": "下载证书并双击打开，系统会自动导入「钥匙串访问」。",
        "2": "在「登录」或「系统」钥匙串中找到 Sniffy Root CA 证书并双击。",
        "3": "展开「信任」一栏，将「使用此证书时」设置为「始终信任」。",
        "4": "关闭窗口，输入系统密码确认更改即可生效。"
      },
      "windows": {
        "1": "点击上方「下载证书 (.crt)」保存根证书文件到本地。",
        "2": "双击下载的 .crt 文件，在弹出的对话框中点击「安装证书」。",
        "3": "存储位置选择「本地计算机」，并将证书放入「受信任的根证书颁发机构」存储区。",
        "4": "点击「完成」，重启浏览器后即可对 HTTPS 流量解密。"
      }
    },
    "subtitle": "根证书管理与安装引导",
    "title": "证书"
